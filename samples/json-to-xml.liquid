{% comment %}
  JSON to XML Transformation Template
  Converts JSON data to XML format
{% endcomment %}
<?xml version="1.0" encoding="utf-8"?>
<root>
{% for item in rows %}
  <item>
  {% for prop in item %}
    <{{ prop[0] }}>{{ prop[1] }}</{{ prop[0] }}>
  {% endfor %}
  </item>
{% endfor %}
</root>