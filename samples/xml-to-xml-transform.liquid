<?xml version="1.0" encoding="utf-8"?>
<invoice generated="{{ 'now' | date: '%Y-%m-%dT%H:%M:%SZ' }}">
  <header>
    <invoice_number>INV-{{ content.order.@id | upcase }}</invoice_number>
    <order_status>{{ content.order.@status | upcase }}</order_status>
    <priority_level>{{ content.order.@priority }}</priority_level>
  </header>
  
  <billing_info>
    <company_name>{{ content.order.customer.name }}</company_name>
    <customer_type>{{ content.order.customer.@type | capitalize }}</customer_type>
    <contact_email>{{ content.order.customer.email | downcase }}</contact_email>
    <billing_address>
      <line1>{{ content.order.customer.address.street }}</line1>
      <line2>{{ content.order.customer.address.city }}, {{ content.order.customer.address.state }} {{ content.order.customer.address.zip }}</line2>
      <country>{{ content.order.customer.address.country }}</country>
    </billing_address>
    <contacts>
      {% for phone in content.order.customer.phone %}
      <phone type="{{ phone.@type }}">{{ phone.#text }}</phone>
      {% endfor %}
    </contacts>
  </billing_info>
  
  <line_items>
    {% assign subtotal = 0.0 %}
    {% assign total_discount = 0.0 %}
    {% for item in content.order.items.item %}
    {% assign item_price = item.price.#text | times: 1.0 %}
    {% assign item_qty = item.quantity | times: 1 %}
    {% assign item_discount_pct = item.discount | times: 1 %}
    {% assign line_subtotal = item_price | times: item_qty %}
    {% assign line_discount = line_subtotal | times: item_discount_pct | divided_by: 100.0 %}
    {% assign line_total = line_subtotal | minus: line_discount %}
    {% assign subtotal = subtotal | plus: line_subtotal %}
    {% assign total_discount = total_discount | plus: line_discount %}
    <line_item position="{{ forloop.index }}" sku="{{ item.@sku }}">
      <description>{{ item.name }}</description>
      <category>{{ item.@category | upcase }}</category>
      <unit_price currency="{{ item.price.@currency }}">{{ item_price }}</unit_price>
      <quantity>{{ item_qty }}</quantity>
      <subtotal>{{ line_subtotal }}</subtotal>
      {% if item_discount_pct > 0 %}
      <discount_percent>{{ item_discount_pct }}</discount_percent>
      <discount_amount>{{ line_discount }}</discount_amount>
      {% endif %}
      <line_total>{{ line_total }}</line_total>
      {% if item.tags.tag %}
      <tags>
        {% if item.tags.tag.first %}
        {% for tag in item.tags.tag %}
        <tag>{{ tag | upcase }}</tag>
        {% endfor %}
        {% else %}
        <tag>{{ item.tags.tag | upcase }}</tag>
        {% endif %}
      </tags>
      {% endif %}
    </line_item>
    {% endfor %}
  </line_items>
  
  <summary>
    <subtotal>{{ subtotal }}</subtotal>
    <total_discount>{{ total_discount }}</total_discount>
    {% assign shipping_cost = content.order.shipping.cost | times: 1.0 %}
    <shipping method="{{ content.order.shipping.@method }}" carrier="{{ content.order.shipping.@carrier }}">
      <cost>{{ shipping_cost }}</cost>
      <estimated_delivery_days>{{ content.order.shipping.estimated_days }}</estimated_delivery_days>
    </shipping>
    {% assign grand_total = subtotal | minus: total_discount | plus: shipping_cost %}
    <grand_total currency="{{ content.order.payment.currency }}">{{ grand_total }}</grand_total>
  </summary>
  
  <payment>
    <method>{{ content.order.payment.@method | replace: '_', ' ' | capitalize }}</method>
    <status>{{ content.order.payment.@status | upcase }}</status>
    <authorized_amount>{{ content.order.payment.amount }}</authorized_amount>
  </payment>
  
  {% if content.order.notes.note.size > 0 %}
  <order_notes>
    {% for note in content.order.notes.note %}
    <note id="{{ forloop.index }}">
      <timestamp>{{ note.@timestamp }}</timestamp>
      <author>{{ note.@author | capitalize }}</author>
      <content>{{ note.#text }}</content>
    </note>
    {% endfor %}
  </order_notes>
  {% endif %}
  
  <metadata>
    <total_items>{{ content.order.items.item.size }}</total_items>
    <has_discounts>{% if total_discount > 0 %}true{% else %}false{% endif %}</has_discounts>
    <is_express_shipping>{% if content.order.shipping.@method == 'express' %}true{% else %}false{% endif %}</is_express_shipping>
  </metadata>
</invoice>