{
  "name": "dot-liquid-template-debugger",
  "displayName": "Dot Liquid Template Debugger",
  "description": "Professional Dot Liquid Template Debugger with line-by-line execution, variable transformation history, and multi-format support (JSON, XML, CSV).",
  "icon": "images/ltdlogo2.png",
  "version": "2.0.0",
  "publisher": "SoubhikDevTools",
  "repository": {
    "type": "git",
    "url": "https://github.com/soubhik7/LiquidTemplateDebugger.git"
  },
  "bugs": {
    "url": "https://github.com/soubhik7/LiquidTemplateDebugger/issues"
  },
  "homepage": "https://github.com/soubhik7/LiquidTemplateDebugger#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "liquid",
    "template",
    "debugger",
    "dotliquid",
    "azure",
    "logicapps",
    "transformation"
  ],
  "activationEvents": [
    "onCommand:liquid-debugger.start",
    "onLanguage:liquid"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "liquid",
        "extensions": [
          ".liquid"
        ],
        "aliases": [
          "Liquid",
          "liquid"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "liquid-debugger.start",
        "title": "Liquid: Start Debugging",
        "icon": "$(debug-start)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == liquid",
          "command": "liquid-debugger.start",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "resourceLangId == liquid",
          "command": "liquid-debugger.start",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "liquid-debugger-sidebar",
          "title": "Liquid Debugger",
          "icon": "$(debug-alt)"
        }
      ]
    },
    "views": {
      "liquid-debugger-sidebar": [
        {
          "id": "liquid-debugger-launcher",
          "name": "Liquid Debugger Launcher"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "liquid-debugger-launcher",
        "contents": "Professional Dot Liquid Debugger\n\n[Launch Full Debugger](command:liquid-debugger.start)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build-all",
    "build-all": "npm run build-webview && npm run compile",
    "build-webview": "cd ../webview-ui && npm install --legacy-peer-deps && npm run build && mkdir -p ../vscode-extension/webview-ui && cp -r dist ../vscode-extension/webview-ui/",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^10.3.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0",
    "csv-parse": "^5.5.3",
    "csv-stringify": "^6.4.5",
    "fast-xml-parser": "^5.8.0",
    "liquidjs": "^10.10.0"
  }
}
