{
  "name": "liquid-template-debugger-pro",
  "displayName": "Liquid Template Debugger Pro",
  "description": "Step-by-step debugger for Liquid templates with format transformation support",
  "version": "1.0.5",
  "publisher": "SoubhikDevTools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/liquid-template-debugger-pro.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/liquid-template-debugger-pro/issues"
  },
  "homepage": "https://github.com/yourusername/liquid-template-debugger-pro#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "liquid",
    "template",
    "debugger",
    "dotliquid",
    "shopify"
  ],
  "activationEvents": [
    "onCommand:liquid-debugger.start",
    "onLanguage:liquid"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "liquid",
        "extensions": [".liquid"],
        "aliases": ["Liquid", "liquid"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "liquid-debugger.start",
        "title": "Liquid: Start Debugging",
        "icon": "$(debug-start)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == liquid",
          "command": "liquid-debugger.start",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "resourceLangId == liquid",
          "command": "liquid-debugger.start",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "liquidjs": "^10.10.0",
    "fast-xml-parser": "^4.3.2",
    "csv-parse": "^5.5.3",
    "csv-stringify": "^6.4.5",
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0"
  }
}