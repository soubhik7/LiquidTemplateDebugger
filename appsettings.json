{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LiquidTemplateDebugger": "Debug"
    }
  },
  "AllowedHosts": "*",
  
  "LiquidDebugger": {
    "MaxTemplateSize": 1000000,
    "MaxDataSize": 10000000,
    "SessionTimeout": "00:30:00",
    "EnableMetrics": true,
    "EnableTracing": true,
    "MaxConcurrentSessions": 100
  },
  
  "Security": {
    "AllowedDirectories": [
      "./samples",
      "./templates",
      "./data"
    ],
    "MaxTemplateSize": 1000000,
    "MaxDataSize": 10000000,
    "EnableAuthentication": false,
    "EnableRateLimiting": true,
    "RateLimitPerMinute": 100,
    "RequireHttps": false
  },
  
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  },
  
  "FeatureFlags": {
    "EnableAdvancedDebugging": true,
    "EnableFormatConversion": true,
    "EnableMultiSession": false,
    "EnableAuthentication": false,
    "EnableAuditLogging": true,
    "EnableMetrics": true,
    "EnableHealthChecks": true,
    "EnableSwagger": true
  },
  
  "Database": {
    "Provider": "InMemory",
    "ConnectionString": "",
    "CommandTimeout": 30,
    "EnableRetry": true,
    "MaxRetryCount": 3
  },
  
  "Monitoring": {
    "ApplicationInsightsKey": "",
    "EnableHealthChecks": true,
    "HealthCheckInterval": "00:01:00",
    "EnableDetailedErrors": false
  },
  
  "Jwt": {
    "Issuer": "LiquidDebugger",
    "Audience": "LiquidDebuggerAPI",
    "Key": "CHANGE_THIS_TO_A_SECURE_KEY_IN_PRODUCTION_AT_LEAST_32_CHARACTERS",
    "ExpirationHours": 8
  },
  
  "RateLimiting": {
    "GlobalLimit": 100,
    "GlobalWindow": "00:01:00",
    "LoadEndpointLimit": 10,
    "LoadEndpointWindow": "00:01:00",
    "StepEndpointLimit": 1000,
    "StepEndpointWindow": "00:01:00"
  },
  
  "Caching": {
    "EnableDistributedCache": false,
    "CacheProvider": "Memory",
    "DefaultExpiration": "00:15:00",
    "RedisConnectionString": ""
  }
}