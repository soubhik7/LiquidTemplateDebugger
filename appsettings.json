{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LiquidTemplateDebugger": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AI": {
    "Enabled": false,
    "ApiKey": null,
    "DefaultModel": "gemini-1.5-flash",
    "SensitivePatterns": [
      "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
      "\\b\\d{3}[-.]?\\d{3}[-.]?\\d{4}\\b",
      "\\b\\d{4}[-\\s]?\\d{4}[-\\s]?\\d{4}[-\\s]?\\d{4}\\b",
      "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "\\b[A-Za-z0-9]{32,}\\b",
      "Bearer\\s+[A-Za-z0-9\\-._~+/]+=*",
      "(?i)api[_-]?key['\"]?\\s*[:=]\\s*['\"]?[A-Za-z0-9]{20,}"
    ],
    "MaxRetries": 3,
    "TimeoutSeconds": 30
  }
}